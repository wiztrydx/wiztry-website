---
/**
 * ネイビー背景に浮かぶパーティクルネットワーク。
 * 親要素は position: relative であること。density: 1000pxあたりの粒子数目安。
 */
interface Props {
  density?: number;
  opacity?: number;
}
const { density = 10, opacity = 0.55 } = Astro.props;
---

<canvas class="particle-canvas" data-particles data-density={density} style={`opacity:${opacity}`}></canvas>

<script>
  function initParticles() {
    document.querySelectorAll<HTMLCanvasElement>('canvas[data-particles]:not([data-ready])').forEach((canvas) => {
      canvas.dataset.ready = '1';
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      let w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);
      type P = { x: number; y: number; vx: number; vy: number; r: number };
      let pts: P[] = [];
      const mouse = { x: -9999, y: -9999 };

      const resize = () => {
        const rect = canvas.parentElement!.getBoundingClientRect();
        w = rect.width; h = rect.height;
        canvas.width = w * dpr; canvas.height = h * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const target = Math.round((w / 1000) * parseFloat(canvas.dataset.density || '10') * 10);
        pts = Array.from({ length: target }, () => ({
          x: Math.random() * w, y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.35, vy: (Math.random() - 0.5) * 0.35,
          r: Math.random() * 1.6 + 0.6,
        }));
      };
      resize();
      new ResizeObserver(resize).observe(canvas.parentElement!);

      canvas.parentElement!.addEventListener('pointermove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left; mouse.y = e.clientY - rect.top;
      });
      canvas.parentElement!.addEventListener('pointerleave', () => { mouse.x = -9999; mouse.y = -9999; });

      const LINK = 130;
      let raf = 0;
      const frame = () => {
        ctx.clearRect(0, 0, w, h);
        for (const p of pts) {
          p.x += p.vx; p.y += p.vy;
          if (p.x < -10) p.x = w + 10; if (p.x > w + 10) p.x = -10;
          if (p.y < -10) p.y = h + 10; if (p.y > h + 10) p.y = -10;
          // マウスに軽く引き寄せられる
          const dx = mouse.x - p.x, dy = mouse.y - p.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < 180 * 180 && d2 > 1) {
            p.x += (dx / Math.sqrt(d2)) * 0.25;
            p.y += (dy / Math.sqrt(d2)) * 0.25;
          }
        }
        for (let i = 0; i < pts.length; i++) {
          for (let j = i + 1; j < pts.length; j++) {
            const a = pts[i], b = pts[j];
            const dx = a.x - b.x, dy = a.y - b.y;
            const d = Math.hypot(dx, dy);
            if (d < LINK) {
              ctx.strokeStyle = `rgba(90, 160, 255, ${(1 - d / LINK) * 0.35})`;
              ctx.lineWidth = 1;
              ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
            }
          }
        }
        for (const p of pts) {
          ctx.fillStyle = 'rgba(140, 200, 255, 0.85)';
          ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fill();
        }
        raf = requestAnimationFrame(frame);
      };

      // 画面内にあるときだけ描画
      const vio = new IntersectionObserver(([e]) => {
        if (e.isIntersecting) { cancelAnimationFrame(raf); raf = requestAnimationFrame(frame); }
        else cancelAnimationFrame(raf);
      });
      vio.observe(canvas);
    });
  }
  initParticles();
  document.addEventListener('astro:page-load', initParticles);
</script>
