---
import ParticleField from './ParticleField.astro';

interface Props {
  en: string;
  jp: string;
  desc?: string;
  /** /gen/ph-*.webp などの背景画像パス */
  bg?: string;
}
const { en, jp, desc, bg } = Astro.props;
const bgStyle = bg
  ? `background: linear-gradient(100deg, rgba(5,13,30,0.92) 0%, rgba(10,22,48,0.72) 50%, rgba(10,22,48,0.25) 100%), url('${bg}') center / cover no-repeat, var(--bg-navy-grad);`
  : '';
---

<section class="page-hero" style={bgStyle}>
  <div class="aurora" aria-hidden="true"><i></i><i></i><i></i></div>
  <ParticleField density={6} opacity={0.4} />
  <div class="container" style="position:relative">
    {/* SEO: h1は日本語タイトル（.jp）に割り当てる。英語の大見出しは装飾なのでpのまま（見た目はCSSクラス依存で不変） */}
    <p class="en reveal is-in">{en}</p>
    <h1 class="jp reveal is-in">{jp}</h1>
    {desc && <p class="desc reveal is-in">{desc}</p>}
  </div>
</section>
