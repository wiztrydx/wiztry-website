---
import { CLIENTS } from '../data/site';

interface Props {
  /** marquee: トップ用の流れる2段表示 / grid: 一覧グリッド */
  mode?: 'grid' | 'marquee';
}
const { mode = 'grid' } = Astro.props;

const half = Math.ceil(CLIENTS.length / 2);
const rowA = CLIENTS.slice(0, half);
const rowB = CLIENTS.slice(half);
---

<script>
  // マーキーはCSSアニメ駆動（全環境で確実）。タッチ中だけ一時停止する最小限の制御のみ行う。
  // ※過去の教訓: JSでscrollLeftを書く自走方式は、iOSの挙動差やscrollイベント自己発火で壊れる
  function initMarqueeTouchPause() {
    document.querySelectorAll<HTMLElement>('.marquee:not([data-mq])').forEach((mq) => {
      mq.dataset.mq = '1';
      const track = mq.querySelector<HTMLElement>('.marquee-track');
      if (!track) return;
      const pause = () => { track.style.animationPlayState = 'paused'; };
      const resume = () => { track.style.animationPlayState = 'running'; };
      mq.addEventListener('touchstart', pause, { passive: true });
      mq.addEventListener('touchend', resume, { passive: true });
      mq.addEventListener('touchcancel', resume, { passive: true });
    });
  }
  initMarqueeTouchPause();
  document.addEventListener('astro:page-load', initMarqueeTouchPause);
</script>

{/* ロゴ画像はlazyにしない: グリッドはセルごとの遅延ポップインで壊れて見え、
    マーキーは横流れで次々ビューポートに入るため流れの途中でポップインする。
    計250KB弱と軽量なので先読みが正解。revealもセル個別ではなくグリッド全体に1回。 */}
{
  mode === 'grid' ? (
    <ul class="logo-grid reveal">
      {CLIENTS.map((c) => (
        <li class:list={['logo-cell', `logo--${c.shape}`]} title={c.name}>
          <img src={`/clients/${c.slug}.webp`} alt={c.name} decoding="async" />
        </li>
      ))}
    </ul>
  ) : (
    <div>
      {[rowA, rowB].map((row, i) => (
        <div class="marquee" style={i === 1 ? 'margin-top:16px' : ''}>
          <div class:list={['marquee-track', { 'marquee-track--rev': i === 1 }]}>
            {[...row, ...row].map((c) => (
              <div class:list={['logo-cell', `logo--${c.shape}`]} title={c.name}>
                <img src={`/clients/${c.slug}.webp`} alt={c.name} decoding="async" />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  )
}
