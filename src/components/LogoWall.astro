---
import { CLIENTS } from '../data/site';

interface Props {
  /** marquee: トップ用の流れる2段表示 / grid: 一覧グリッド */
  mode?: 'grid' | 'marquee';
}
const { mode = 'grid' } = Astro.props;

const half = Math.ceil(CLIENTS.length / 2);
const rowA = CLIENTS.slice(0, half);
const rowB = CLIENTS.slice(half);
---

<script>
  // タッチ端末: マーキーを指でスワイプできるネイティブスクロールに切替え、
  // 触っていない間はゆっくり自動で流す
  function initTouchMarquee() {
    if (!window.matchMedia('(pointer: coarse)').matches) return;
    document.querySelectorAll<HTMLElement>('.marquee:not([data-touch])').forEach((mq) => {
      mq.dataset.touch = '1';
      mq.classList.add('marquee--touch');
      const track = mq.querySelector<HTMLElement>('.marquee-track');
      if (!track) return;
      let paused = false;
      let resumeTimer: ReturnType<typeof setTimeout>;
      const pause = () => {
        paused = true;
        clearTimeout(resumeTimer);
        resumeTimer = setTimeout(() => (paused = false), 2000);
      };
      mq.addEventListener('touchstart', pause, { passive: true });
      mq.addEventListener('scroll', pause, { passive: true });
      const drift = () => {
        if (!paused) {
          mq.scrollLeft += 0.5;
          const half = track.scrollWidth / 2;
          if (mq.scrollLeft >= half) mq.scrollLeft -= half;
        }
        requestAnimationFrame(drift);
      };
      requestAnimationFrame(drift);
    });
  }
  initTouchMarquee();
  document.addEventListener('astro:page-load', initTouchMarquee);
</script>

{
  mode === 'grid' ? (
    <ul class="logo-grid">
      {CLIENTS.map((c) => (
        <li class:list={['logo-cell', `logo--${c.shape}`, 'reveal']} title={c.name}>
          <img src={`/clients/${c.slug}.webp`} alt={c.name} loading="lazy" />
        </li>
      ))}
    </ul>
  ) : (
    <div>
      {[rowA, rowB].map((row, i) => (
        <div class="marquee" style={i === 1 ? 'margin-top:16px' : ''}>
          <div class:list={['marquee-track', { 'marquee-track--rev': i === 1 }]}>
            {[...row, ...row].map((c) => (
              <div class:list={['logo-cell', `logo--${c.shape}`]} title={c.name}>
                <img src={`/clients/${c.slug}.webp`} alt={c.name} loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  )
}
