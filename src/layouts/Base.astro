---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SITE, NAV, YOUTUBE } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  /** ヘッダー背景が濃色ヒーローに重なるページは true（トップ・下層ヒーロー） */
  onDark?: boolean;
  ogImage?: string;
}

const {
  title,
  description = SITE.description,
  onDark = true,
  ogImage = '/og.png',
} = Astro.props;

const pageTitle = title
  ? `${title} | WizTry株式会社（熊本の生成AI研修・AIエージェント導入支援）`
  : 'WizTry株式会社｜熊本の生成AI研修・AIエージェント導入支援';
const canonical = new URL(Astro.url.pathname, SITE.domain).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.domain,
  email: SITE.email,
  logo: `${SITE.domain}/logos/mark-512.png`,
  foundingDate: '2023-07',
  founder: { '@type': 'Person', name: SITE.ceo },
  sameAs: [YOUTUBE.url],
  areaServed: { '@type': 'AdministrativeArea', name: '熊本県' },
  knowsAbout: ['生成AI研修', 'AIエージェント導入支援', 'DX支援', 'リスキリング'],
  address: {
    '@type': 'PostalAddress',
    addressRegion: '熊本県',
    addressLocality: '熊本市西区',
    streetAddress: '春日1丁目14番1号 くまもと森都心プラザ2階 XOSS POINT. Room4',
    postalCode: '860-0047',
    addressCountry: 'JP',
  },
  description: SITE.description,
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/logos/mark-32.png" type="image/png" />
    <link rel="apple-touch-icon" href="/logos/mark-192.png" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, SITE.domain).href} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Outfit:wght@500;700;800&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <div class="site-loader" id="siteLoader" aria-hidden="true">
      <span class="curtain curtain--top"></span>
      <span class="curtain curtain--bottom"></span>
      <div class="site-loader-inner">
        <div class="site-loader-logo">
          <img src="/logos/wiztry-logo-white.png" alt="" width="168" height="40" />
          <i class="logo-shine"></i>
        </div>
        <span class="site-loader-bar"><i></i></span>
        <span class="site-loader-count" id="loaderCount">0</span>
      </div>
      <div class="site-loader-stars" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i></div>
    </div>
    <div class="scroll-progress" aria-hidden="true"></div>
    <header class:list={['site-header', { 'on-dark': onDark }]} id="siteHeader">
      <div class="container inner">
        <a href="/" class="brand" aria-label="WizTry株式会社 トップページ">
          <img class="logo-dark" src="/logos/wiztry-logo.png" alt="WizTry" width="126" height="30" />
          <img class="logo-white" src="/logos/wiztry-logo-white.png" alt="WizTry" width="126" height="30" />
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="メニュー" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <nav class="gnav" id="gnav">
          {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
          <a href="/contact/" class="btn btn--primary">お問い合わせ <span class="arrow">→</span></a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="top">
          <div class="brand">
            <img src="/logos/wiztry-logo-white.png" alt="WizTry株式会社" width="126" height="30" />
            <p class="addr">
              {SITE.name}<br />
              {SITE.address}<br />
              {SITE.email}
            </p>
          </div>
          <div>
            <h4>SERVICE</h4>
            <ul>
              <li><a href="/service/#training">生成AI導入研修</a></li>
              <li><a href="/service/#agent">AIエージェント導入支援</a></li>
              <li><a href="/service/#subsidy">補助金・助成金の活用</a></li>
              <li><a href="/works/">導入実績</a></li>
            </ul>
          </div>
          <div>
            <h4>COMPANY</h4>
            <ul>
              <li><a href="/about/">会社案内・理念</a></li>
              <li><a href="/blog/">ブログ</a></li>
              <li><a href="/contact/">お問い合わせ</a></li>
              <li><a href="/privacy/">プライバシーポリシー</a></li>
              <li>
                <a href={YOUTUBE.url} target="_blank" rel="noopener" aria-label="YouTubeチャンネル KOTARO AI & VIDEO">
                  ▶ YouTube（{YOUTUBE.name}）
                </a>
              </li>
            </ul>
          </div>
        </div>
        <div class="copy">
          <span>© {new Date().getFullYear()} WizTry Inc. All rights reserved.</span>
          <span>KUMAMOTO, JAPAN</span>
        </div>
      </div>
    </footer>

    <script>
      // ページ遷移でbodyが差し替わるため、window直付けのリスナーは1回だけ登録し、
      // 参照する要素はナビゲーションごとに更新する（多重登録によるカクつき防止）
      let headerEl: HTMLElement | null = null;
      let barEl: HTMLElement | null = null;
      const onScrollGlobal = () => {
        headerEl?.classList.toggle('is-solid', window.scrollY > 40);
        if (barEl) {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          barEl.style.width = `${max > 0 ? (window.scrollY / max) * 100 : 0}%`;
        }
      };
      let windowBound = false;

      function initPage() {
        headerEl = document.getElementById('siteHeader');
        barEl = document.querySelector<HTMLElement>('.scroll-progress');
        onScrollGlobal();
        if (!windowBound) {
          windowBound = true;
          window.addEventListener('scroll', onScrollGlobal, { passive: true });
        }

        // モバイルナビ
        const toggle = document.getElementById('navToggle');
        const gnav = document.getElementById('gnav');
        toggle?.addEventListener('click', () => {
          const open = gnav?.classList.toggle('open');
          toggle.classList.toggle('open', !!open);
          toggle.setAttribute('aria-expanded', String(!!open));
          document.body.style.overflow = open ? 'hidden' : '';
        });
        gnav?.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => {
            gnav.classList.remove('open');
            toggle?.classList.remove('open');
            document.body.style.overflow = '';
          })
        );

        // Reveal on scroll
        // 注意: thresholdに比率を使うと「画面より縦に長い要素」が永遠に発火しない
        // （比率の最大値=viewport/要素高がthreshold未満になるため）。0.01+rootMarginで判定する
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.01, rootMargin: '0px 0px -60px 0px' }
        );
        document.querySelectorAll('.reveal:not(.is-in)').forEach((el) => io.observe(el));

        // 数字カウントアップ（.count[data-to][data-decimals]）
        const cio = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (!e.isIntersecting) return;
              cio.unobserve(e.target);
              const el = e.target as HTMLElement;
              const to = parseFloat(el.dataset.to || '0');
              const dec = parseInt(el.dataset.decimals || '0');
              const dur = 1400;
              const t0 = performance.now();
              const tick = (t: number) => {
                const p = Math.min((t - t0) / dur, 1);
                const eased = 1 - Math.pow(1 - p, 3);
                el.textContent = (to * eased).toFixed(dec);
                if (p < 1) requestAnimationFrame(tick);
              };
              requestAnimationFrame(tick);
            });
          },
          { threshold: 0.5 }
        );
        document.querySelectorAll('.count').forEach((el) => cio.observe(el));

        // 3Dチルト（.tilt）
        const fine = window.matchMedia('(pointer: fine)').matches;
        const noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (fine && !noMotion) {
          document.querySelectorAll<HTMLElement>('.tilt').forEach((el) => {
            if (el.dataset.tiltReady) return;
            el.dataset.tiltReady = '1';
            if (!el.querySelector('.tilt-shine')) {
              const shine = document.createElement('span');
              shine.className = 'tilt-shine';
              el.appendChild(shine);
            }
            el.addEventListener('pointermove', (e) => {
              const r = el.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width;
              const py = (e.clientY - r.top) / r.height;
              el.style.transform = `perspective(900px) rotateX(${(0.5 - py) * 6}deg) rotateY(${(px - 0.5) * 8}deg) translateY(-4px)`;
              el.style.setProperty('--mx', `${px * 100}%`);
              el.style.setProperty('--my', `${py * 100}%`);
            });
            el.addEventListener('pointerleave', () => {
              el.style.transform = '';
            });
          });
        }
      }

      document.addEventListener('astro:page-load', initPage);

      // 初回ロードのブランドイントロ（セッション内1回だけ）: %カウント→分割カーテン
      // 重要: ClientRouterのページ遷移でbodyが差し替わるとローダーDOMが復活するため、
      // 遷移後は必ず除去する（過去に「0%のまま固まる」バグの原因になった）
      document.addEventListener('astro:after-swap', () => {
        document.getElementById('siteLoader')?.remove();
        document.documentElement.classList.remove('is-loading');
      });
      (() => {
        const loader = document.getElementById('siteLoader');
        if (!loader) return;
        let seen = true;
        try {
          seen = !!sessionStorage.getItem('wt-intro');
          if (!seen) sessionStorage.setItem('wt-intro', '1');
        } catch (e) {
          seen = true; // プライベートモード等では演出スキップ
        }
        if (seen || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          loader.remove();
          return;
        }
        try {
          document.documentElement.classList.add('is-loading');
          const count = document.getElementById('loaderCount');
          const DUR = 1200;
          const t0 = performance.now();
          let finished = false;
          const tick = (t: number) => {
            const p = Math.min((t - t0) / DUR, 1);
            if (count) count.textContent = String(Math.round((1 - Math.pow(1 - p, 2.2)) * 100));
            if (p < 1 && !finished) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          const done = () => {
            if (finished) return;
            finished = true;
            if (count) count.textContent = '100';
            loader.classList.add('is-done');
            document.documentElement.classList.remove('is-loading');
            setTimeout(() => loader.remove(), 1100);
          };
          window.addEventListener('load', () => setTimeout(done, Math.max(0, DUR - (performance.now() - t0)) + 100), { once: true });
          if (document.readyState === 'complete') setTimeout(done, DUR + 100);
          setTimeout(done, 2500); // 保険: 何があっても2.5秒で開く
        } catch (e) {
          loader.remove();
          document.documentElement.classList.remove('is-loading');
        }
      })();


      // タップ波紋（タッチ端末の全ボタン共通）
      if (window.matchMedia('(pointer: coarse)').matches) {
        document.addEventListener(
          'pointerdown',
          (e) => {
            const btn = (e.target as HTMLElement).closest('.btn');
            if (!btn) return;
            const r = btn.getBoundingClientRect();
            const rip = document.createElement('span');
            rip.className = 'tap-ripple';
            const size = Math.max(r.width, r.height);
            rip.style.width = rip.style.height = `${size}px`;
            rip.style.left = `${e.clientX - r.left}px`;
            rip.style.top = `${e.clientY - r.top}px`;
            btn.appendChild(rip);
            setTimeout(() => rip.remove(), 600);
          },
          { passive: true }
        );
      }

      // マグネティックボタン（primary系のみ・ポインタ精細時）
      if (window.matchMedia('(pointer: fine)').matches && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const magnetize = () => {
          document.querySelectorAll<HTMLElement>('.btn--primary:not([data-mag])').forEach((btn) => {
            btn.dataset.mag = '1';
            btn.addEventListener('pointermove', (e) => {
              const r = btn.getBoundingClientRect();
              const dx = e.clientX - (r.left + r.width / 2);
              const dy = e.clientY - (r.top + r.height / 2);
              btn.style.transform = `translate(${dx * 0.18}px, ${dy * 0.3}px)`;
            });
            btn.addEventListener('pointerleave', () => {
              btn.style.transform = '';
            });
          });
        };
        magnetize();
        document.addEventListener('astro:page-load', magnetize);
      }
    </script>
  </body>
</html>
