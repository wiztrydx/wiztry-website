---
import Base from '../layouts/Base.astro';
import SectionHead from '../components/SectionHead.astro';
import CtaBand from '../components/CtaBand.astro';
import LogoWall from '../components/LogoWall.astro';
import Stats from '../components/Stats.astro';
import ParticleField from '../components/ParticleField.astro';
import { MEDIA, YOUTUBE } from '../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const NUMBERS = [
  { value: 90, decimals: 0, unit: '社以上', label: '累計支援企業数', note: '※2026年7月時点' },
  { value: 4.8, decimals: 1, unit: ' / 5.0', label: '研修満足度', note: '※受講後アンケート平均' },
  { value: 12, decimals: 0, unit: '業種+', label: '支援業種の広がり', note: '' },
  { value: 2023, decimals: 0, unit: '年', label: '熊本にて創業', note: '' },
];
---

<Base onDark={true}>
  <!-- 1-1 Hero -->
  <section class="hero">
    <div class="hero-beams" aria-hidden="true"><i></i><i></i></div>
    <div class="hero-lights" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
    <div class="hero-streaks" aria-hidden="true"><i></i><i></i><i></i></div>
    <ParticleField density={13} opacity={0.6} />
    <div class="container hero-inner">
      <div class="hero-copy reveal">
        <span class="hero-label">KUMAMOTO × GENERATIVE AI</span>
        <h1 class="hero-title">生成AIを、<br />事業の力に。</h1>
        <p class="hero-sub">
          熊本から、企業のAI活用を成果まで導く。講師が隣で伴走するハンズオン研修と、Claude
          Code・Codexによる実務自動化エージェントの開発。WizTryは「使えるようになるまで」を約束する、企業のAIパートナーです。
        </p>
        <div class="hero-actions">
          <a href="/contact/" class="btn btn--primary btn--lg">無料で相談する <span class="arrow">→</span></a>
          <a href="/service/" class="btn btn--ghost-white">サービスを見る</a>
        </div>
      </div>
      <div class="scroll-indicator" aria-hidden="true">
        <span class="si-text">SCROLL</span>
        <span class="si-track"><i class="si-comet"></i></span>
        <span class="si-ring"></span>
      </div>
    </div>
    <div class="hero-stats reveal reveal-d2">
      <div class="container">
        <Stats />
      </div>
    </div>
  </section>

  <!-- 1-2 選ばれる理由 -->
  <section class="section section--alt">
    <div class="container">
      <SectionHead en="WHY WIZTRY" title="選ばれ続ける、3つの理由" />
      <div class="grid grid--3">
        <div class="card num-card tilt reveal reveal-d1">
          <span class="num">01</span>
          <h3>対面ハンズオンで、確実に身につく</h3>
          <p>
            オンライン教材を見るだけでは、現場は変わりません。講師がすぐ隣で一緒に手を動かし、その場でつまずきを解消。基本のAI活用から実務レベルの応用まで、「分かる」で終わらせず「使える」まで引き上げます。
          </p>
        </div>
        <div class="card num-card tilt reveal reveal-d2">
          <span class="num">02</span>
          <h3>研修だけじゃない、開発技術力</h3>
          <p>
            Claude Code・Codex・Dify・GASを使い、問い合わせ対応や資料作成、日報・データ集計といった日常業務を自動化するAIエージェントを構築。研修会社であると同時に、実装まで担う開発パートナーです。
          </p>
        </div>
        <div class="card num-card tilt reveal reveal-d3">
          <span class="num">03</span>
          <h3>リピートされる満足度</h3>
          <p>
            受講後アンケートの満足度は平均4.8（5点満点）。2年目・3年目の継続プログラムや2期目研修など、一度導入いただいた企業様からのリピートが多いことが、成果の何よりの証明です。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 1-3 サービス2本柱 -->
  <section class="section section--deco" style="padding-top: clamp(40px, 5vw, 64px);">
    <div class="ticker" aria-hidden="true" style="margin-bottom: clamp(40px, 6vw, 72px);">
      <span>AI TRAINING&nbsp;/&nbsp;AI AGENT&nbsp;/&nbsp;DX&nbsp;/&nbsp;KUMAMOTO&nbsp;/&nbsp;AI TRAINING&nbsp;/&nbsp;AI AGENT&nbsp;/&nbsp;DX&nbsp;/&nbsp;KUMAMOTO&nbsp;/&nbsp;</span>
    </div>
    <div class="container">
      <SectionHead en="SERVICE" title="事業内容" />
      <div class="grid grid--2">
        <a href="/service/#training" class="card service-card tilt reveal reveal-d1">
          <div class="zoom-media"><img src="/gen/scene-training.webp" alt="講師が隣で伴走する対面ハンズオン形式の生成AI研修" loading="lazy" /></div>
          <div class="service-card-body">
            <h3>生成AI導入研修</h3>
            <p>
              ChatGPT・Gemini・Claude・Codexなどの生成AIを、業種と業務に合わせたカリキュラムで。基礎の使い方から、GAS・Difyを使った業務自動化まで、対面ハンズオンで確実に定着させます。
            </p>
            <span class="link-arrow">詳しく見る <span class="arrow">→</span></span>
          </div>
        </a>
        <a href="/service/#agent" class="card service-card tilt reveal reveal-d2">
          <div class="zoom-media"><img src="/gen/scene-agent-dev.webp" alt="実務を自動化するAIエージェントの開発イメージ" loading="lazy" /></div>
          <div class="service-card-body">
            <h3>AIエージェント導入支援</h3>
            <p>
              Claude Code・Codexを核に、貴社の実務を自動化する高度なAIエージェントを構築。要件整理からPoC、本番運用、運用後の伴走まで一貫して支援します。
            </p>
            <span class="link-arrow">詳しく見る <span class="arrow">→</span></span>
          </div>
        </a>
      </div>
      <p class="service-subsidy-note reveal reveal-d3">
        熊本県リスキリング応援補助金・人材開発支援助成金などの活用もご提案できます
        <a href="/service/#subsidy">詳しく見る <span class="arrow">→</span></a>
      </p>
    </div>
  </section>

  <!-- 1-4 実績ロゴ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHead
        en="CLIENTS"
        title="導入企業様（一部）"
        lead="業種・業界を問わず、熊本を中心に多くの企業様にご利用いただいています。"
      />
      <LogoWall mode="marquee" />
      <div class="text-center mt-64">
        <a href="/works/" class="btn btn--ghost">導入実績を見る <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- 1-5 数字で見るWizTry -->
  <section class="section section--navy sec-ghost numbers-sec" data-ghost="NUMBERS">
    <ParticleField density={6} opacity={0.35} />
    <div class="container">
      <SectionHead en="NUMBERS" title="数字で見るWizTry" center />
      <div class="grid grid--4">
        {
          NUMBERS.map((n, i) => (
            <div class:list={['stat', 'reveal', `reveal-d${i + 1}`]}>
              <div class="value">
                <span class="count" data-to={n.value} data-decimals={n.decimals}>
                  0
                </span>
                <span class="unit">{n.unit}</span>
              </div>
              <div class="label">{n.label}</div>
              {n.note && <span class="note">{n.note}</span>}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 1-5.5 YouTube -->
  <section class="section">
    <div class="container">
      <div class="yt-band card tilt reveal reveal--zoom">
        <div class="zoom-media yt-media">
          <img src="/gen/youtube-studio.webp" alt="YouTubeチャンネル KOTARO AI & VIDEO の制作スタジオイメージ" loading="lazy" />
        </div>
        <div class="yt-body">
          <span class="yt-en">YOUTUBE</span>
          <h2>{YOUTUBE.name}</h2>
          <p>{YOUTUBE.description}</p>
          <a href={YOUTUBE.url} target="_blank" rel="noopener" class="btn btn--navy">チャンネルを見る <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- 1-6 メディア掲載 -->
  <section class="section section--deco">
    <div class="container">
      <SectionHead en="MEDIA" title="メディア掲載・登壇" center />
      <ul class="media-list">
        {
          MEDIA.map((m, i) => (
            <li class:list={['reveal', `reveal-d${(i % 4) + 1}`]}>
              <a href={m.url} target="_blank" rel="noopener" class="media-link">
                <span class="media-tag">{m.outlet}</span>
                <span class="media-title">{m.title}</span>
                <span class="media-go" aria-hidden="true">↗</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 1-7 ブログ最新3件 -->
  <section class="section section--alt">
    <div class="container">
      <SectionHead en="BLOG" title="AI活用ブログ" />
      {
        posts.length > 0 ? (
          <div class="grid grid--3">
            {posts.map((post, i) => (
              <a href={`/blog/${post.id}/`} class:list={['card', 'post-card', 'tilt', 'reveal', `reveal-d${i + 1}`]}>
                <div class="zoom-media"><img class="thumb" src={post.data.thumb} alt={post.data.title} loading="lazy" /></div>
                <div class="body">
                  <span class="tag">{post.data.tag}</span>
                  <h3>{post.data.title}</h3>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}
                  </time>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="text-center" style="color:var(--muted)">
            ただいま準備中です。近日公開いたします。
          </p>
        )
      }
      <div class="text-center mt-64">
        <a href="/blog/" class="btn btn--ghost">もっと見る <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- 1-8 CTA -->
  <CtaBand />
</Base>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    color: #fff;
    padding-top: var(--header-h);
    background: var(--navy-950);
    overflow: hidden;
  }
  /* 背景画像: スロー・ケンバーンズズーム */
  .hero::before {
    content: '';
    position: absolute;
    inset: -4%;
    background: url('/gen/hero-ai-wave.webp') center / cover no-repeat;
    animation: heroZoom 22s ease-in-out infinite alternate;
    will-change: transform;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgba(5, 13, 30, 0.9) 0%, rgba(10, 22, 48, 0.55) 45%, rgba(10, 22, 48, 0.12) 100%);
  }
  @keyframes heroZoom {
    from { transform: scale(1) translate(0, 0); }
    to { transform: scale(1.14) translate(-1.2%, -2.2%); }
  }
  .hero :global(.particle-canvas) { z-index: 2; }

  /* 回転する光のビーム（コニックグラデーション2枚が逆回転） */
  .hero-beams {
    position: absolute;
    inset: 0;
    z-index: 1;
    mix-blend-mode: screen;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-beams i {
    position: absolute;
    width: 160vmax;
    height: 160vmax;
    top: 50%;
    left: 68%;
    margin: -80vmax 0 0 -80vmax;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.5;
  }
  .hero-beams i:nth-child(1) {
    background: conic-gradient(
      transparent 0deg, transparent 40deg,
      rgba(47, 107, 255, 0.28) 60deg, transparent 85deg,
      transparent 180deg, rgba(55, 200, 240, 0.2) 205deg, transparent 230deg, transparent 360deg
    );
    animation: beamSpin 34s linear infinite;
  }
  .hero-beams i:nth-child(2) {
    background: conic-gradient(
      transparent 0deg, rgba(55, 200, 240, 0.16) 25deg, transparent 55deg,
      transparent 200deg, rgba(90, 140, 255, 0.18) 230deg, transparent 260deg, transparent 360deg
    );
    animation: beamSpin 46s linear infinite reverse;
  }
  @keyframes beamSpin { to { transform: rotate(360deg); } }

  /* 流れる光のストリーク（データ彗星） */
  .hero-streaks {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-streaks i {
    position: absolute;
    width: 220px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg, transparent, rgba(150, 210, 255, 0.9), #fff);
    filter: drop-shadow(0 0 6px rgba(55, 200, 240, 0.9));
    transform: rotate(-24deg);
    opacity: 0;
    animation: streak 7s ease-in infinite;
  }
  .hero-streaks i:nth-child(1) { top: 18%; left: 58%; animation-delay: 1.2s; }
  .hero-streaks i:nth-child(2) { top: 42%; left: 74%; animation-delay: 3.8s; animation-duration: 8.5s; width: 160px; }
  .hero-streaks i:nth-child(3) { top: 8%; left: 80%; animation-delay: 6.2s; animation-duration: 9.5s; width: 130px; }
  @keyframes streak {
    0%, 88% { opacity: 0; transform: rotate(-24deg) translateX(0); }
    90% { opacity: 1; }
    100% { opacity: 0; transform: rotate(-24deg) translateX(-46vw); }
  }

  /* スクロールでヒーローの文字がゆっくり退場（対応ブラウザのみ） */
  @supports (animation-timeline: view()) {
    .hero-copy {
      animation: heroExit linear both;
      animation-timeline: view();
      animation-range: exit 0% exit 70%;
    }
  }
  @keyframes heroExit {
    to { opacity: 0; transform: translateY(-46px); }
  }

  /* 漂う光（screen合成でヒーローの光源が呼吸するように動く） */
  .hero-lights {
    position: absolute;
    inset: 0;
    z-index: 1;
    mix-blend-mode: screen;
    pointer-events: none;
  }
  .hero-lights i {
    position: absolute;
    border-radius: 50%;
    filter: blur(56px);
  }
  .hero-lights i:nth-child(1) {
    width: 560px; height: 560px; top: 2%; right: 2%;
    background: radial-gradient(circle, rgba(55, 200, 240, 0.5), transparent 66%);
    animation: lightA 10s ease-in-out infinite alternate;
  }
  .hero-lights i:nth-child(2) {
    width: 420px; height: 420px; bottom: 6%; right: 26%;
    background: radial-gradient(circle, rgba(47, 107, 255, 0.55), transparent 66%);
    animation: lightB 13s ease-in-out infinite alternate;
  }
  .hero-lights i:nth-child(3) {
    width: 320px; height: 320px; top: 34%; left: 34%;
    background: radial-gradient(circle, rgba(130, 170, 255, 0.4), transparent 66%);
    animation: lightC 16s ease-in-out infinite alternate;
  }
  .hero-lights i:nth-child(4) {
    width: 240px; height: 240px; top: 12%; left: 6%;
    background: radial-gradient(circle, rgba(55, 200, 240, 0.3), transparent 66%);
    animation: lightB 19s ease-in-out infinite alternate-reverse;
  }
  @keyframes lightA {
    from { transform: translate(0, 0) scale(1); opacity: 0.55; }
    50% { opacity: 0.95; }
    to { transform: translate(-90px, 70px) scale(1.22); opacity: 0.65; }
  }
  @keyframes lightB {
    from { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50% { opacity: 0.9; }
    to { transform: translate(70px, -60px) scale(1.18); opacity: 0.6; }
  }
  @keyframes lightC {
    from { transform: translate(0, 0) scale(0.9); opacity: 0.35; }
    50% { opacity: 0.8; }
    to { transform: translate(-60px, -50px) scale(1.25); opacity: 0.45; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero::before, .hero-lights i, .hero-beams i, .hero-streaks i, .hero-copy { animation: none; }
  }
  .hero-inner {
    flex: 1;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 3;
  }
  .hero-copy {
    max-width: 720px;
    padding-block: clamp(44px, 8vw, 72px);
  }
  /* 初回ロードの段階フェードイン */
  .hero-label, .hero-title, .hero-sub, .hero-actions {
    opacity: 0;
    transform: translateY(26px);
    animation: heroRise 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-title { animation-delay: 0.15s; }
  .hero-sub { animation-delay: 0.32s; }
  .hero-actions { animation-delay: 0.5s; }
  @keyframes heroRise {
    to { opacity: 1; transform: none; }
  }
  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-en);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--cyan-400);
    margin-bottom: 24px;
  }
  .hero-label::before {
    content: '';
    width: 34px;
    height: 2px;
    background: var(--accent-grad);
    border-radius: 2px;
  }
  .hero-title {
    color: #fff;
    font-size: clamp(40px, 6.2vw, 74px);
    font-weight: 900;
    letter-spacing: 0.01em;
  }
  .hero-sub {
    margin-top: 28px;
    max-width: 46em;
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.86);
  }
  .hero-actions {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    margin-top: 40px;
  }
  .hero-stats {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(5, 13, 30, 0.32);
    backdrop-filter: blur(6px);
    padding-block: clamp(28px, 4vw, 40px);
    position: relative;
    z-index: 3;
  }
  .scroll-indicator {
    position: absolute;
    right: 0;
    bottom: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: rgba(255, 255, 255, 0.65);
  }
  .si-text {
    writing-mode: vertical-rl;
    font-family: var(--font-en);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.34em;
    animation: siGlow 2.6s ease-in-out infinite;
  }
  /* 光の彗星が線路を流れ落ちる */
  .si-track {
    position: relative;
    display: block;
    width: 2px;
    height: 64px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.14);
    overflow: hidden;
  }
  .si-comet {
    position: absolute;
    left: 0;
    top: -40%;
    width: 100%;
    height: 40%;
    border-radius: 2px;
    background: linear-gradient(180deg, transparent, var(--cyan-400) 60%, #fff);
    box-shadow: 0 0 10px rgba(55, 200, 240, 0.9);
    animation: siComet 2.6s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  /* 着地点で波紋が広がる */
  .si-ring {
    position: relative;
    display: block;
    width: 7px;
    height: 7px;
  }
  .si-ring::before,
  .si-ring::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
  }
  .si-ring::before {
    background: var(--cyan-400);
    box-shadow: 0 0 8px rgba(55, 200, 240, 0.9);
    animation: siGlow 2.6s ease-in-out infinite;
  }
  .si-ring::after {
    border: 1.5px solid rgba(55, 200, 240, 0.8);
    animation: siRipple 2.6s cubic-bezier(0.2, 0.6, 0.4, 1) infinite;
  }
  @keyframes siComet {
    0% { top: -45%; opacity: 0; }
    12% { opacity: 1; }
    78% { top: 105%; opacity: 1; }
    100% { top: 105%; opacity: 0; }
  }
  @keyframes siRipple {
    0%, 55% { transform: scale(1); opacity: 0.9; }
    100% { transform: scale(3.4); opacity: 0; }
  }
  @keyframes siGlow {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 1; }
  }
  @media (max-width: 760px) {
    .scroll-indicator {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .si-comet, .si-ring::after, .si-ring::before, .si-text { animation: none; }
  }

  /* ---------- Service pillar cards ---------- */
  .service-card {
    display: block;
    overflow: hidden;
  }
  .service-card img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
    width: 100%;
  }
  .service-card-body {
    padding: clamp(24px, 3vw, 36px);
  }
  .service-card-body h3 {
    font-size: 21px;
    margin-bottom: 14px;
  }
  .service-card-body p {
    color: var(--ink-soft);
    font-size: 15px;
    margin-bottom: 20px;
  }
  .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 14.5px;
    color: var(--blue-500);
  }
  .service-subsidy-note {
    margin-top: clamp(28px, 4vw, 44px);
    text-align: center;
    font-size: 14.5px;
    color: var(--ink-soft);
  }
  .service-subsidy-note a {
    margin-left: 6px;
    font-weight: 700;
    color: var(--blue-500);
  }

  /* ---------- Numbers ---------- */
  .numbers-sec {
    position: relative;
    background:
      linear-gradient(rgba(10, 22, 48, 0.82), rgba(10, 22, 48, 0.88)),
      url('/gen/neural-grid.webp') center / cover no-repeat, var(--bg-navy-grad);
    overflow: hidden;
  }
  .numbers-sec .stat {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.13);
