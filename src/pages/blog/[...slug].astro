---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import ParticleField from '../../components/ParticleField.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const toc = headings.filter((h) => h.depth === 2);

// 関連記事: 同タグ優先 → 足りなければ新しい順で補完（自分は除く）
const allPosts = (await getCollection('blog'))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const related = [
  ...allPosts.filter((p) => p.data.tag === post.data.tag),
  ...allPosts.filter((p) => p.data.tag !== post.data.tag),
].slice(0, 3);

const fmt = (d: Date) =>
  `${d.getUTCFullYear()}.${String(d.getUTCMonth() + 1).padStart(2, '0')}.${String(d.getUTCDate()).padStart(2, '0')}`;

const heroStyle =
  "background: linear-gradient(100deg, rgba(5,13,30,0.92) 0%, rgba(10,22,48,0.72) 50%, rgba(10,22,48,0.25) 100%), url('/gen/ph-blog.webp') center / cover no-repeat, var(--bg-navy-grad);";

// SEO: 記事ごとの構造化データ（BlogPosting）
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: new URL(post.data.thumb, 'https://wiztrydx.com').href,
  datePublished: post.data.pubDate.toISOString(),
  inLanguage: 'ja',
  author: { '@type': 'Organization', name: 'WizTry株式会社', url: 'https://wiztrydx.com' },
  publisher: { '@type': 'Organization', name: 'WizTry株式会社', logo: { '@type': 'ImageObject', url: 'https://wiztrydx.com/logos/mark-512.png' } },
  mainEntityOfPage: new URL(`/blog/${post.id}/`, 'https://wiztrydx.com').href,
};

// SEO: パンくず構造化データ
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://wiztrydx.com/' },
    { '@type': 'ListItem', position: 2, name: 'ブログ', item: 'https://wiztrydx.com/blog/' },
    { '@type': 'ListItem', position: 3, name: post.data.title },
  ],
};
---

<Base title={post.data.title} description={post.data.description} onDark={true} ogImage={post.data.thumb} ogType="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />
  <section class="page-hero post-hero" style={heroStyle}>
    <div class="aurora" aria-hidden="true"><i></i><i></i><i></i></div>
    <ParticleField density={6} opacity={0.4} />
    <div class="container" style="position:relative">
      <span class="en post-kicker reveal">BLOG</span>
      <p class="jp reveal reveal-d1">
        {post.data.tag}
        <span class="post-date">{fmt(post.data.pubDate)}</span>
      </p>
      <h1 class="post-title reveal reveal-d2">{post.data.title}</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {
        toc.length > 1 && (
          <details class="post-toc" id="postToc">
            <summary>目次</summary>
            <ol>
              {toc.map((h) => (
                <li>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ol>
          </details>
        )
      }
      <article class="prose">
        <Content />
      </article>

      <div class="post-cta reveal">
        <p>関連するご相談はお気軽に</p>
        <a href="/contact/" class="btn btn--primary">お問い合わせする <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  {
    related.length > 0 && (
      <section class="section section--alt related-sec">
        <div class="container">
          <div class="sec-head reveal">
            <span class="en">RELATED</span>
            <h2>あわせて読みたい</h2>
          </div>
          <div class="grid grid--3">
            {related.map((p, i) => (
              <a
                href={`/blog/${p.id}/`}
                class:list={['card', 'post-card', 'tilt', 'reveal', `reveal-d${i + 1}`]}
              >
                <div class="zoom-media">
                  <img class="thumb" src={p.data.thumb} alt={p.data.title} loading="lazy" decoding="async" />
                </div>
                <div class="body">
                  <span class="tag">{p.data.tag}</span>
                  <h3>{p.data.title}</h3>
                  <time datetime={p.data.pubDate.toISOString()}>{fmt(p.data.pubDate)}</time>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CtaBand />
</Base>

<style>
  .post-kicker {
    display: inline-block;
    font-size: 13px;
    letter-spacing: 0.3em;
    color: var(--cyan-400);
    margin-bottom: 4px;
  }
  .post-hero .post-date {
    font-family: var(--font-en);
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 600;
  }
  .post-hero .post-date::before {
    content: '/';
    margin-right: 14px;
    color: rgba(255, 255, 255, 0.3);
  }
  .post-title {
    font-family: var(--font-jp);
    font-weight: 800;
    font-size: clamp(24px, 3.6vw, 38px);
    letter-spacing: 0.02em;
    line-height: 1.55;
    margin-top: 18px;
    max-width: 22em;
  }
  .post-cta {
    max-width: 720px;
    margin: 64px auto 0;
    text-align: center;
    padding: 40px clamp(20px, 4vw, 40px);
    background: var(--bg-alt);
    border-radius: var(--radius);
  }
  .post-cta p {
    font-weight: 700;
    font-size: 15px;
    color: var(--ink-soft);
    margin-bottom: 18px;
  }

  /* 目次 */
  .post-toc {
    max-width: 720px;
    margin: 0 auto 40px;
    background: var(--bg-alt);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 6px 24px;
  }
  .post-toc summary {
    cursor: pointer;
    font-weight: 700;
    padding: 14px 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
  }
  .post-toc summary::-webkit-details-marker {
    display: none;
  }
  .post-toc summary::before {
    content: '☰';
    color: var(--blue-500);
    font-size: 14px;
  }
  .post-toc summary::after {
    content: '＋';
    margin-left: auto;
    color: var(--muted);
    transition: transform 0.25s ease;
  }
  .post-toc[open] summary::after {
    transform: rotate(45deg);
  }
  .post-toc ol {
    padding: 2px 0 16px 10px;
    display: grid;
    gap: 8px;
    counter-reset: toc;
  }
  .post-toc li {
    counter-increment: toc;
    font-size: 14.5px;
  }
  .post-toc li::before {
    content: counter(toc, decimal-leading-zero);
    font-family: var(--font-en);
    font-weight: 700;
    color: var(--blue-500);
    margin-right: 10px;
    font-size: 12px;
  }
  .post-toc a:hover {
    color: var(--blue-500);
  }
  .prose :global(h2) {
    scroll-margin-top: 90px;
  }
</style>

<script>
  // PCでは目次を開いた状態に
  function openTocOnDesktop() {
    const toc = document.getElementById('postToc') as HTMLDetailsElement | null;
    if (toc && window.matchMedia('(min-width: 769px)').matches) toc.open = true;
  }
  openTocOnDesktop();
  document.addEventListener('astro:page-load', openTocOnDesktop);
</script>
